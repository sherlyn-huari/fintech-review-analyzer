{
  "name": "Clean App Reviews Dashboard - Fixed Sentiment Order",
  "dataColors": [
    "#EF4444",
    "#9CA3AF",
    "#22C55E",
    "#3B82F6",
    "#111827"
  ],
  "background": "#F7F8FA",
  "foreground": "#111827",
  "tableAccent": "#3B82F6",
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "show": true,
            "color": {
              "solid": {
                "color": "#FFFFFF"
              }
            },
            "transparency": 0
          }
        ],
        "visualHeader": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": {
              "solid": {
                "color": "#111827"
              }
            },
            "fontSize": 12,
            "alignment": "left"
          }
        ]
      }
    }
  }
}